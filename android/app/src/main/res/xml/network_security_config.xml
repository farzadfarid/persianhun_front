<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext HTTP to the local backend server (192.168.1.212).
        When the backend is moved to HTTPS in production, remove this domain entry
        and set cleartextTrafficPermitted to false.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.212</domain>
    </domain-config>

    <!-- All other connections must use HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
